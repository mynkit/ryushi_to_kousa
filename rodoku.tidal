  -- # theta (cF 0 "synthTheta") # dis (cF 0 "synthDis")
  # hpf 800
  # hpq (range 0.0 0.4 $ slow 2.5 rand)
  # amp 0.2


d10
  $ (|* gain 1)
  $ mix ((|+ n 12).(|* gain 0.6))
  -- $ whenmod 16 12 ((|- n 2).(|* gain 1.08))
  $ s "superhammondBend"
  # gain 0.85
  # n "<b2,fs3,e3,a3>"
  # voice 1
  # scReverb 0.9 # ice 0.3
  # room 0.8 # sz 0.8
  # ntag "intro"

d10 silence


do
  setFm "osc0" 0.6
  setFm "osc1" 0.5
  setFm "osc2" 0.5
  setFm "osc3" 0.4

-- 1st row
mod12
  $ segment 64
  $ amp 0.1
  # cutoff 800
  # scReverb (cF 0 "osc0") # ice ((cF 0 "osc0")*0.3)
  # dry (((cF 0 "osc1") * 2) + 1)
  # pingpong ((cF 0 "osc2")) # pingpongt (3/8) # pingpongfb (cF 0 "osc3")

-- 2nd row
mod13
  $ segment 64
  $ amp 0.1
  # cutoff 3000
  # scReverb (cF 0 "osc0") # ice ((cF 0 "osc0")*0.3)
  # dry (((cF 0 "osc1") * 2) + 1)
  # pingpong ((cF 0 "osc2")) # pingpongt (3/8) # pingpongfb (cF 0 "osc3")

-- 3rd row
mod14
  $ segment 64
  $ amp 0.1
  # cutoff 3000
  # scReverb (cF 0 "osc0") # ice ((cF 0 "osc0")*0.3)
  # dry (((cF 0 "osc1") * 2) + 1)
  # pingpong ((cF 0 "osc2")) # pingpongt (3/8) # pingpongfb (cF 0 "osc3")

-- 4th row
mod15
  $ segment 64
  $ amp 0.1
  # cutoff 3000
  # scReverb (cF 0 "osc0") # ice ((cF 0 "osc0")*0.3)
  # dry (((cF 0 "osc1") * 2) + 1)
  # pingpong ((cF 0 "osc2")) # pingpongt (3/8) # pingpongfb (cF 0 "osc3")

-- 5th row
mod16
