  $ amp 0.1
  # cutoff 3000
  # scReverb (cF 0 "osc0") # ice ((cF 0 "osc0")*0.3)
  # dry (((cF 0 "osc1") * 2) + 1)
  # pingpong ((cF 0 "osc2")) # pingpongt (3/8) # pingpongfb 0.8



d4
  $ degradeBy 0.1
  $ s "~ coffee/3 ~ ~"
  # n (choose [7,8])
