setbpm 90

-- @@ 栁川さん: 04 5:30

-- 開始時

d1
  $ (|* amp 0.10)
  $ mix ((|+ n 12).(|* amp 0.7))
  $ slow 2
  $ s "SinOscSynthBend [~ [~SinOscSynthBend/2]]"
  # n "<e4,a4,b4> <a5,d5,e5>"
  # room 0.9 # sz 0.3 # dry 2.8
  # pingpong 0.05 # pingpongt (3/8) # pingpongfb 0.8
  # resi 1
  # sustain 5
  # sustainpedal 0.25
  # slide 0.5
  # theta "-0.1 0.1"
  # amp "0.4 0.25"
  # ntag "yanagawa04"

do
  -- 雨の水滴
  let
    bubbleSizeMin = 20
    bubbleSizeMax = 80
  d7
    $ (|* amp 0.06)
    $ fast (range 1 30 $ fast 5 rand)
    -- $ (|* sustain (range 1.2 0.9 $ slow 317 rand*rand))
    $ (|* freq (range 3.5 2.6 $ rand**4))
    $ s "simpleSineWave"
    # sustain (range (1/bubbleSizeMax) (min (1/bubbleSizeMin) 0.02) rand)
    # freq (range (bubbleSizeMax**2) (bubbleSizeMin**2) (sqrt rand))
    # accelerate (range (sqrt (304/bubbleSizeMax)) (sqrt (304/bubbleSizeMin)) rand)
    # amp (range 0.1 1 (rand**2))
    -- # room 0.8 # sz 0.7
    # resi 1
    # hpf 1000
    # gain 1.0
    # ntag "yanagawa04"


-- 「微風のあと」〜

d2
  $ (|* amp 0.11)
  $ mix ((|+ n 12).(|* amp 0.7))
  $ slow 1.5
  $ s "~ SinOscSynthBend ~ ~"
  # n "<<e3,a5,<b5 fs5 b5 fs5>> <a3,af5,e4>>"
  # room 0.9 # sz 0.3 # dry 2.8
  # pingpong 0.05 # pingpongt (4/8) # pingpongfb 0.8
  # resi 1
  # sustain 5
  # sustainpedal 0.25
  # slide 0.5
  # theta (range (-0.2) 0.2 $ fast 3.2 rand)
  # amp 0.2
  # ntag "yanagawa04"

-- 「蛇口から溢れたような」〜

d7
  -- 水の流れ
  $ (|* amp 0.1)
  $ (|* gain (range 0.6 1 (fast 1.0 rand)))
  $ (|* gain (range 0 0.27 (fast 15 rand)))
  $ density (range 100 1000 $ slow (range 2.1 3.1 $ slow 5.5 rand) sine)
  $ s "SinOscSynthBend"
  # sustain (range 0.008 0.08 (rand))
  # accelerate (range 2 5 (rand))
  # n (range 54 (11) (rand))
  # resi 0.5
  # lpf 3000
  # theta (range (-0.1) (0.1) (fast 1.5 rand))
  # amp 0.6
  # gain 2.0
  # ntag "yanagawa04"


-- 「等距離に現れる音素を抱いて」〜

d9
  -- rotate
  $ (|* amp 0.2)
  $ sometimesBy 0.1 (degradeBy 1)
  -- $ sometimesBy 0.02 ((ply (choose [4,8,10])).(|* amp 0.6))
  $ (|* amp (range 1 0.8 rand))
  $ (|+ n 12)
  $ s "superfm*32"
  # n "<e5,a5>"
  # sustain 0.01
  # amp 0.03
  # room 0.8 # sz 0.8 #dry 0
  # resi 1
  # hpf 600
  # lpf 2000
  # theta (range (1) (-1) $ slow 6 line)
  # ntag "yanagawa04"



