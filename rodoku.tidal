  # ntag "resonant"

-- Part: sineharm

d6
  $ slow 4
  -- $ (0.125 ~>)
  $ mix ((|+ n 12).(|* amp 0.5))
  $ every' 4 3 (degradeBy "0 1")
  $ every' 4 2 (degradeBy "1 0")
  $ every' 4 1 (degradeBy "0 0")
  $ every' 4 0 (degradeBy "0 1")
  $ s "[~[vibratoSineWave]] ~ ~ [vibratoSineWave] "
